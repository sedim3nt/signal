{
  "name": "signal-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "ingest": "node scripts/ingest-youtube.mjs",
    "ingest:daily": "node scripts/ingest-youtube.mjs --days 92 --scan-limit 30 --limit-per-channel 8 --discovery rss",
    "ingest:seed": "node scripts/ingest-youtube.mjs --days 92 --scan-limit 40 --limit-per-channel 4 --discovery yt-dlp",
    "ingest:full": "node scripts/ingest-youtube.mjs --days 92 --scan-limit 120 --discovery yt-dlp",
    "ingest:metadata": "node scripts/ingest-youtube.mjs --days 92 --scan-limit 120 --metadata-only --discovery yt-dlp",
    "synthesize": "node scripts/synthesize-signal.mjs",
    "db:build": "node scripts/build-database.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^1.17.0",
    "openai": "^6.42.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
